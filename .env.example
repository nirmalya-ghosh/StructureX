GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Supabase browser auth for Google sign-in
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# Optional, only needed by /api/saveSecure if you use server-side encrypted storage
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ENCRYPTION_KEY=replace_with_a_long_random_secret

# Cloudflare Turnstile CAPTCHA. When both keys are present, auth forms and
# protected AI endpoints require a valid Turnstile token.
TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key
